# ----------------------------------------
# PROJECT 1: HAVERI
# ----------------------------------------
api.haveri.tech {
    # DYNAMIC CORS HANDLING for multiple origins
    @haveri_cors_origins header Origin "https://haveri.tech" "https://www.haveri.tech"
    
    # Consolidate all headers into a SINGLE block
    header {
        # Set the origin dynamically based on the matcher
        Access-Control-Allow-Origin "{header.origin}"
        # Standard CORS headers
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "*"
        Access-Control-Allow-Credentials "true"
        Access-Control-Max-Age "86400"
        
        # Security Headers
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
    }

    # Handle preflight OPTIONS requests
    @options method OPTIONS
    respond @options 204
    
    # Proxy to the backend
    reverse_proxy backend:8000
}

# ----------------------------------------
# PROJECT 2: JURISTI
# ----------------------------------------
api.juristi.tech {
    # Handle preflight OPTIONS requests
    @options method OPTIONS
    respond @options 204

    # Consolidate all headers into a SINGLE block
    header {
        # Standard CORS headers
        Access-Control-Allow-Origin "https://juristi.tech"
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "*"
        Access-Control-Allow-Credentials "true"
        Access-Control-Max-Age "86400"
        
        # Security Headers
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
    }
    
    # Proxy to the backend
    reverse_proxy juristi-backend:8000
}