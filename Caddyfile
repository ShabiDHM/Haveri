    email shabanbala@gmail.com
}

# ----------------------------------------
# PROJECT 1: HAVERI
# ----------------------------------------
# Frontend/Main Domain Proxy (If applicable)
www.haveri.tech {
    reverse_proxy backend:8000
}

# API Subdomain
api.haveri.tech {
    reverse_proxy backend:8000
}

# ----------------------------------------
# PROJECT 2: JURISTI
# ----------------------------------------
# API Subdomain
api.juristi.tech {
    reverse_proxy juristi-backend:8000 {
        # PHOENIX: Keep SSE connections alive
        transport http {
            read_timeout 10m
        }
    }
}