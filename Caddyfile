}

# ----------------------------------------
# PROJECT 1: HAVERI
# ----------------------------------------
www.haveri.tech {
    reverse_proxy backend:8000 {
        transport http {
            read_timeout 10m
        }
    }
}

api.haveri.tech {
    reverse_proxy backend:8000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Port {server_port}
        transport http {
            read_timeout 10m
        }
    }
}

# ----------------------------------------
# PROJECT 2: JURISTI
# ----------------------------------------
api.juristi.tech {
    reverse_proxy juristi-backend:8000 {
        # PHOENIX FIX: Inform Backend of the secure transport layer
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Port {server_port}
        header_up X-Forwarded-Proto {scheme}

        transport http {
            read_timeout 10m
        }
    }
}