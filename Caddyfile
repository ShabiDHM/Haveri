# ----------------------------------------
# PROJECT 1: HAVERI (Primary / Existing)
# ----------------------------------------
api.haveri.tech {
    # CORS HEADERS (Modify origin if haveri has a different frontend URL)
    header {
        Access-Control-Allow-Origin "https://haveri.tech"
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "*"
        Access-Control-Allow-Credentials "true"
        Access-Control-Max-Age "86400"
    }

    # PREFLIGHT HANDLING
    @options method OPTIONS
    respond @options 204
    
    # Internal Docker Routing
    reverse_proxy backend:8000

    # SECURITY HEADERS
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
    }
}

# ----------------------------------------
# PROJECT 2: JURISTI (Secondary / New)
# ----------------------------------------
api.juristi.tech {
    # CORS HEADERS (This is the critical fix)
    header {
        Access-Control-Allow-Origin "https://juristi.tech"
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "*"
        Access-Control-Allow-Credentials "true"
        Access-Control-Max-Age "86400"
    }

    # PREFLIGHT HANDLING (Responds to the browser's permission check)
    @options method OPTIONS
    respond @options 204
    
    # Internal Docker Routing
    reverse_proxy juristi-backend:8000

    # SECURITY HEADERS
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
    }
}